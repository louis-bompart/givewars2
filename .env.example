# Discord Application credentials (fill these in on the Discord Developer Portal)
NEXT_PUBLIC_DISCORD_CLIENT_ID="TODO_REPLACE_WITH_DISCORD_CLIENT_ID"
DISCORD_CLIENT_ID="TODO_REPLACE_WITH_DISCORD_CLIENT_ID"
DISCORD_CLIENT_SECRET="TODO_REPLACE_WITH_DISCORD_CLIENT_SECRET"

# MongoDB Atlas Database connection
MONGO_MONGODB_URI="TODO_REPLACE_WITH_MONGODB_URI"

# Field-Level Encryption Secret (Must be exactly 32 characters/bytes for AES-256)
ENCRYPTION_KEY="TODO_REPLACE_WITH_32_CHAR_SECRET_KEY"

# Restricted Discord Guild ID(s) for the Activity (Supports multiple comma-separated IDs, e.g. "YOUR_PRODUCTION_SERVER_ID,YOUR_TEST_SERVER_ID")
NEXT_PUBLIC_ALLOWED_GUILD_ID="YOUR_PRODUCTION_SERVER_ID"
